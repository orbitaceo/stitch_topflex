# ============================================================
# LavaStore Pro — Variáveis de Ambiente
# COPIE ESTE ARQUIVO PARA .env.local E PREENCHA OS VALORES REAIS
# NUNCA COMMITE O .env.local
# ============================================================

# ——— BANCO DE DADOS ———
DATABASE_URL="postgresql://lavastore:sua_senha@localhost:5432/lavastore_db"

# ——— REDIS ———
REDIS_URL="redis://localhost:6379"

# ——— JWT (RS256) ———
# Gere com: openssl genrsa -out private.pem 2048
# E depois: openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ——— API CONFIG ———
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ——— CORS / DOMÍNIO ———
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ——— MERCADO PAGO ———
MP_ACCESS_TOKEN="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MP_PUBLIC_KEY="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MP_WEBHOOK_SECRET="sua_assinatura_secreta_do_webhook"

# ——— UPLOAD DE ARQUIVOS (local) ———
UPLOAD_DIR="./uploads"
UPLOAD_MAX_SIZE_MB=10

# ——— EMAIL (SMTP) ———
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app

# ——— SENTRY (Error Tracking) ———
SENTRY_DSN_API=
SENTRY_DSN_WEB=

# ——— NEXT.JS ———
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_MP_PUBLIC_KEY="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
NEXT_PUBLIC_WHATSAPP_NUMBER="5511999999999"

# ——— ADMINER / DEBUG ———
POSTGRES_USER=lavastore
POSTGRES_PASSWORD=sua_senha
POSTGRES_DB=lavastore_db
